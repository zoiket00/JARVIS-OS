# JARVIS-OS FASE 2 — Variables de entorno
# Copia a .env y completa tus valores

ENTORNO=desarrollo
DEPURACION=false

# Base de datos (mismos valores que docker-compose de FASE 1)
POSTGRES_USUARIO=jarvis
POSTGRES_CONTRASENA=jarvis_dev
POSTGRES_BASE=jarvis_db
POSTGRES_HOST=localhost
POSTGRES_PUERTO=5432

# Redis
REDIS_HOST=localhost
REDIS_PUERTO=6379
REDIS_DB=0

# Anthropic — OBLIGATORIO
ANTHROPIC_API_KEY=tu_clave_aqui
MODELO_CLAUDE=claude-sonnet-4-6
MAX_TOKENS=8192

# Vault Obsidian
VAULT_RUTA=c:\Claude - Obsidian\Dios de la IA
