# JARVIS-OS — Variables de entorno
# Copia este archivo a .env y completa tus valores

# Aplicación
ENTORNO=desarrollo
DEPURACION=false

# Base de datos (coincide con los valores por defecto de docker-compose.yml)
POSTGRES_USUARIO=jarvis
POSTGRES_CONTRASENA=jarvis_dev
POSTGRES_BASE=jarvis_db
POSTGRES_HOST=localhost
POSTGRES_PUERTO=5432

# Redis
REDIS_HOST=localhost
REDIS_PUERTO=6379
REDIS_DB=0

# Anthropic
ANTHROPIC_API_KEY=tu_clave_aqui
MODELO_CLAUDE=claude-sonnet-4-6
MAX_TOKENS=8192
